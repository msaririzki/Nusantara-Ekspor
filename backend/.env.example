# ==========================================
# Nusantara Ekspor - Environment Variables
# ==========================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nusantara_ekspor

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# App
APP_NAME=Nusantara Ekspor
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
