# ==========================================
# Nusantara Ekspor - Backend Environment Example
# ==========================================
# Konfigurasi DOMAIN lihat di root ../.env.example
# ==========================================

# ─── Database (Supabase) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.yourproject.supabase.co:5432/postgres

# ─── JWT ─────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── App ─────────────────────────────────────────────────────
APP_NAME=Nusantara Ekspor
APP_VERSION=1.0.0
DEBUG=true

# ─── CORS (domain yang diizinkan akses API) ──────────────────
# Pisahkan dengan koma, tanpa spasi
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com
