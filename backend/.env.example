# ==========================================
# Nusantara Ekspor - Backend Environment Example
# ==========================================
# Salin file ini menjadi .env dan isi nilainya
# ==========================================

# ─── Database (Supabase PostgreSQL) ───────────────────────────
# Ambil dari: Supabase Dashboard → Settings → Database → Connection string
# Pilih mode "URI" lalu ganti [YOUR-PASSWORD] dengan password project-mu
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Supabase Storage ─────────────────────────────────────────
# Ambil dari: Supabase Dashboard → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Gunakan "service_role" key (bukan anon key) untuk operasi storage dari backend
SUPABASE_KEY=your-service-role-key-here
# Nama bucket Storage yang sudah dibuat (set Public di Supabase Storage)
SUPABASE_BUCKET=products

# ─── JWT ─────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── App ─────────────────────────────────────────────────────
APP_NAME=Nusantara Ekspor
APP_VERSION=1.0.0
DEBUG=false

# ─── CORS (domain yang diizinkan akses API) ──────────────────
# Pisahkan dengan koma, tanpa spasi
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com
