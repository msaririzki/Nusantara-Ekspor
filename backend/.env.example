# ==========================================
# Nusantara Ekspor - Backend Environment Example
# ==========================================
# Salin file ini menjadi .env dan isi nilainya
# ==========================================

# ─── Database (SQLite lokal) ──────────────────────────────────
DATABASE_URL=sqlite:///./db.sqlite

# ─── JWT ─────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── App ─────────────────────────────────────────────────────
APP_NAME=Nusra Ekspor
APP_VERSION=1.0.0
DEBUG=false

# ─── CORS (domain yang diizinkan akses API) ──────────────────
# Pisahkan dengan koma, tanpa spasi
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-domain.com

# ─── Port ───────────────────────────────────────────────────
BACKEND_PORT=3000
WEB_PORT=8002
