# ============================================================
# Nusantara Ekspor - Root Environment Example
# Salin file ini menjadi .env lalu sesuaikan nilainya.
# ============================================================

# ─── Domain / URL ───────────────────────────────────────────
# Domain publik aplikasi (tanpa https://)
APP_DOMAIN=your-domain.com

# Backend API URL untuk proxy Vite saat development local
VITE_API_TARGET=http://localhost:8000

# URL publik API yang diakses frontend saat production
VITE_API_BASE_URL=https://your-domain.com

# ─── Port ───────────────────────────────────────────────────
BACKEND_PORT=8000
WEB_PORT=8002
